def _gap(obj, ref):
    if (ref and ref>0 and ref<float("inf")
            and obj and obj<float("inf")):
        return (obj/ref-1)*100
    return None


def print_results_table(records, mode, epsilons, alphas):
    approx = (["GW_Default","GW_MultiInit"]
              + [f"EGW_{e}" for e in epsilons]
              + [f"FGW_{a}" for a in alphas]
              + ["GA"])
    all_keys = approx + ["Exact"]

    def ref(rec):
        return (KNOWN_BEST.get(rec["id"]) if mode=="simple"
                else rec.get("Exact"))

    print(f"\n{'─'*80}")
    print(f"  RESULTS SUMMARY  [{mode.upper()} mode]")
    print(f"{'─'*80}")

    hdr = f"{'Instance':<12} {'n':>3}  "
    for k in all_keys:
        hdr += f"  {LABELS.get(k,k):>14}"
        if k != "Exact": hdr += f"  {'gap%':>5}"
    print(hdr)
    print("─"*min(len(hdr)+20, 200))

    for rec in records:
        r = ref(rec)
        row = f"{rec['id']:<12} {rec['n']:>3}  "
        for k in all_keys:
            v   = rec.get(k)
            g   = _gap(v, r)
            row += f"  {v:>14.1f}" if (v and v<float("inf")) else f"  {'NA':>14}"
            if k != "Exact":
                row += f"  {g:>5.1f}" if g is not None else f"  {'—':>5}"
        print(row)

    print(f"\n  Average gap (approximate methods vs reference):")
    for k in approx:
        gaps = [_gap(r.get(k), ref(r)) for r in records]
        gaps = [g for g in gaps if g is not None]
        if gaps:
            print(f"    {LABELS.get(k,k):<22}: {np.mean(gaps):+.2f}%")


def records_to_df(records, mode, epsilons, alphas):
    all_keys = (["GW_Default","GW_MultiInit"]
                + [f"EGW_{e}" for e in epsilons]
                + [f"FGW_{a}" for a in alphas]
                + ["GA","Exact"])
    def ref(rec):
        return (KNOWN_BEST.get(rec["id"]) if mode=="simple" else rec.get("Exact"))
    rows = []
    for r in records:
        row = {"id":r["id"],"n":r["n"],"mode":mode}
        for k in all_keys:
            v = r.get(k)
            row[k] = v
            row[f"t_{k}"] = r.get(f"t_{k}")
            row[f"gap_{k}"] = _gap(v, ref(r))
        row["exact_optimal"] = r.get("exact_opt")
        rows.append(row)
    return pd.DataFrame(rows)


