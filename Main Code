# 5. Exact solvers (Gurobi)
# ════════════════════════════════════════════════════════════════════════════

def solve_exact_qap(n, F, D, time_limit=7200):
    """
    Exact QAP via Gurobi binary MIQP.
    min Σᵢₖⱼₗ F[i,k]·D[j,l]·x_ij·x_kl,   x ∈ {0,1}^{n×n}
    Returns (best_obj, time_used, is_optimal).
    """
    t0 = time.time()
    try:
        m = gp.Model(); m.setParam("OutputFlag",0)
        m.setParam("NonConvex",2); m.setParam("TimeLimit",time_limit)
        x = m.addVars(n, n, vtype=GRB.BINARY)
        for i in range(n): m.addConstr(sum(x[i,j] for j in range(n)) == 1)
        for j in range(n): m.addConstr(sum(x[i,j] for i in range(n)) == 1)
        obj = gp.QuadExpr()
        for i in range(n):
            for k in range(n):
                for j in range(n):
                    for l in range(n):
                        if F[i,k] != 0 and D[j,l] != 0:
                            obj += F[i,k]*D[j,l]*x[i,j]*x[k,l]
        m.setObjective(obj, GRB.MINIMIZE); m.optimize()
        elapsed = time.time()-t0
        if m.SolCount > 0:
            return m.objVal, elapsed, (m.Status == GRB.OPTIMAL)
    except Exception as e:
        print(f"    Gurobi error: {e}")
    return None, time.time()-t0, False


def solve_exact_cqap(mu, nu, C1, C2, time_limit=7200):
    """
    Exact CQAP via Gurobi continuous MIQP (GW objective + capacity constraints).
    Returns (best_obj, time_used, is_optimal).
    """
    n, mt = len(mu), len(nu)
    t0 = time.time()
    try:
        m = gp.Model(); m.setParam("OutputFlag",0)
        m.setParam("NonConvex",2); m.setParam("TimeLimit",time_limit)
        x = m.addVars(n, mt, lb=0.0, ub=1.0)
        for i in range(n):  m.addConstr(sum(x[i,j] for j in range(mt)) <= mu[i])
        for j in range(mt): m.addConstr(sum(x[i,j] for i in range(n))  == nu[j])
        obj = gp.QuadExpr()
        for i in range(n):
            for k in range(n):
                for j in range(mt):
                    for l in range(mt):
                        coef = (C1[i,k]-C2[j,l])**2
                        if abs(coef) > 1e-12:
                            obj += coef * x[i,j]*x[k,l]
        m.setObjective(obj, GRB.MINIMIZE); m.optimize()
        elapsed = time.time()-t0
        if m.SolCount > 0:
            return m.objVal, elapsed, (m.Status == GRB.OPTIMAL)
    except Exception as e:
        print(f"    Gurobi error: {e}")
    return None, time.time()-t0, False


