def _savefig(fig, path):
    fig.savefig(path, dpi=150, bbox_inches="tight")
    plt.close(fig)
    print(f"  Saved: {path}")


def generate_figures(records, mode, epsilons, alphas, out_dir="results"):
    os.makedirs(out_dir, exist_ok=True)
    approx = (["GW_Default","GW_MultiInit"]
              + [f"EGW_{e}" for e in epsilons]
              + [f"FGW_{a}" for a in alphas]
              + ["GA"])

    def ref(rec):
        return (KNOWN_BEST.get(rec["id"]) if mode=="simple" else rec.get("Exact"))

    names = [r["id"] for r in records]
    x     = np.arange(len(names))

    # Fig 1: Objective comparison
    fig, ax = plt.subplots(figsize=(14, 5))
    plot_keys = ["GW_MultiInit","GW_Default","EGW_0.5","FGW_0.7","GA","Exact"]
    lstyles   = ["--","-.",":","-.",":","--"]
    markers   = ["s","^","v","P","D","o"]
    for key, ls, mk in zip(plot_keys, lstyles, markers):
        vals = [r.get(key) for r in records]
        pts  = [(i,v) for i,v in enumerate(vals) if v and v<float("inf")]
        if not pts: continue
        xi, yi = zip(*pts)
        ax.plot(list(xi), list(yi), label=LABELS.get(key,key),
                color=PALETTE.get(key,"gray"), ls=ls, marker=mk, lw=2, ms=7)
    if mode == "simple":
        bk = [KNOWN_BEST.get(r["id"]) for r in records]
        pts = [(i,v) for i,v in enumerate(bk) if v]
        if pts: xi,yi=zip(*pts); ax.plot(list(xi),list(yi),"k*-",ms=10,lw=2,label="Best Known")
    ax.set_xticks(x); ax.set_xticklabels(names, rotation=25, ha="right", fontsize=9)
    ax.set_ylabel("Objective Value"); ax.legend(bbox_to_anchor=(1.01,1), loc="upper left", fontsize=9)
    ax.set_title(f"Objective Comparison — {'QAPLIB' if mode=='simple' else 'QAPLIB-CQAP'} Instances",
                 fontsize=13, fontweight="bold")
    _savefig(fig, os.path.join(out_dir, "fig1_objective.png"))

    # Fig 2: Optimality gap bar
    valid = [r for r in records if ref(r) and ref(r)<float("inf")]
    if valid:
        ids2 = [r["id"] for r in valid]; x2 = np.arange(len(ids2))
        w    = 0.7/len(approx)
        offs = np.linspace(-(len(approx)-1)/2, (len(approx)-1)/2, len(approx))*w
        fig, ax = plt.subplots(figsize=(14, 5))
        for off, key in zip(offs, approx):
            gaps = [_gap(r.get(key), ref(r)) or 0 for r in valid]
            ax.bar(x2+off, gaps, w, label=LABELS.get(key,key),
                   color=PALETTE.get(key,"gray"), alpha=0.85, edgecolor="white")
        ax.set_xticks(x2); ax.set_xticklabels(ids2, fontsize=9)
        ax.set_ylabel("Gap from Reference (%)"); ax.legend(bbox_to_anchor=(1.01,1), loc="upper left", fontsize=9)
        ax.set_title("Optimality Gap from Reference", fontsize=13, fontweight="bold")
        _savefig(fig, os.path.join(out_dir, "fig2_gap.png"))

    # Fig 3: Runtime scalability
    sizes = [r["n"] for r in records]
    fig, ax = plt.subplots(figsize=(11, 5))
    for key in approx + ["Exact"]:
        ts = [r.get(f"t_{key}") for r in records]
        xi = [s for s,t in zip(sizes,ts) if t and t<float("inf")]
        yi = [t for t in ts if t and t<float("inf")]
        if xi:
            ax.plot(xi, yi, label=LABELS.get(key,key),
                    color=PALETTE.get(key,"gray"), marker="o", lw=2, ms=5)
    ax.set_yscale("log"); ax.set_xlabel("Problem size n"); ax.set_ylabel("Runtime (s, log)")
    ax.set_title("Runtime Scalability", fontsize=13, fontweight="bold"); ax.legend(fontsize=8)
    _savefig(fig, os.path.join(out_dir, "fig3_scalability.png"))

    # Fig 4: Quality-time trade-off
    valid_tr = [r for r in records if ref(r) and ref(r)<float("inf")]
    if valid_tr:
        avg_gap, avg_time = {}, {}
        for key in approx:
            gaps  = [_gap(r.get(key), ref(r)) for r in valid_tr]
            times = [r.get(f"t_{key}") for r in valid_tr]
            gf = [g for g in gaps if g is not None]; tf = [t for t in times if t]
            if gf and tf: avg_gap[key]=np.mean(gf); avg_time[key]=np.mean(tf)
        if avg_gap:
            fig, ax = plt.subplots(figsize=(9, 6))
            for key in avg_gap:
                ax.scatter(avg_time[key], avg_gap[key], color=PALETTE.get(key,"gray"),
                           s=160, zorder=5, edgecolors="white", lw=1.5)
                ax.annotate(LABELS.get(key,key), (avg_time[key], avg_gap[key]),
                            xytext=(7,5), textcoords="offset points", fontsize=9)
            ax.set_xscale("log"); ax.set_xlabel("Avg Runtime (s, log)"); ax.set_ylabel("Avg Gap (%)")
            ax.set_title("Solution Quality vs Computational Time", fontsize=12, fontweight="bold")
            _savefig(fig, os.path.join(out_dir, "fig4_quality_time.png"))

    # Fig 5: Summary heatmap
    valid_hm = [r for r in records if ref(r) and ref(r)<float("inf")]
    if valid_hm:
        ids_hm = [r["id"] for r in valid_hm]
        mat    = np.array([[_gap(r.get(k), ref(r)) or 0 for r in valid_hm] for k in approx])
        fig, ax = plt.subplots(figsize=(max(8,len(ids_hm)*1.1+2), len(approx)*0.6+2))
        im = ax.imshow(mat, cmap="RdYlGn_r", aspect="auto", vmin=0, vmax=np.nanmax(mat))
        ax.set_xticks(range(len(ids_hm))); ax.set_xticklabels(ids_hm, fontsize=9)
        ax.set_yticks(range(len(approx))); ax.set_yticklabels([LABELS.get(k,k) for k in approx], fontsize=9)
        for i in range(len(approx)):
            for j in range(len(ids_hm)):
                v = mat[i,j]
                ax.text(j, i, f"{v:.1f}", ha="center", va="center", fontsize=8,
                        color="black" if v < 15 else "white")
        plt.colorbar(im, ax=ax, label="Gap from Reference (%)")
        ax.set_title("Solution Quality Heatmap", fontsize=12, fontweight="bold")
        _savefig(fig, os.path.join(out_dir, "fig5_heatmap.png"))

    print(f"  ✓  All figures → {os.path.abspath(out_dir)}/")


