def _ask(prompt, choices, default=None):
    while True:
        raw = input(prompt).strip().lower()
        if not raw and default is not None:
            return default
        if raw in choices:
            return raw
        try:
            idx = int(raw)-1
            if 0 <= idx < len(choices):
                return choices[idx]
        except ValueError:
            pass
        print(f"  Please enter one of: {choices}")


def interactive_menu():
    """
    CLI menu. Returns (mode, selected_names, params).
    QAPLIB instances are ALWAYS downloaded automatically to ./qaplib_data/
    """
    print("\n" + "━"*62)
    print("  GW-CQAP Benchmark  |  QAPLIB automatic benchmark runner")
    print("━"*62)
    print(textwrap.dedent("""
    QAPLIB instances are downloaded automatically — no manual step needed.

    Benchmark modes
    ───────────────
    [1]  Simple QAPLIB
         Standard balanced QAP (permutation assignment).
         GW plans → rounded to permutation → QAP objective.
         Gap measured against QAPLIB best-known solutions.

    [2]  Varied QAPLIB  →  CQAP
         Same QAPLIB F,D + random integer capacity/demand constraints.
         GW objective used directly (fractional transport plans).
         Gap measured against Gurobi exact CQAP solver.
    """))

    mode_raw = _ask("Select mode [1/2, default=1]: ", ["1","2"], default="1")
    mode     = "simple" if mode_raw == "1" else "varied"
    print(f"  → Mode: {'Simple QAPLIB (QAP)' if mode=='simple' else 'Varied QAPLIB (CQAP)'}\n")

    # Instance selection
    print("  Available instances:")
    for i, name in enumerate(CURATED_INSTANCES, 1):
        n  = INSTANCE_N.get(name, "?")
        bk = KNOWN_BEST.get(name, "?")
        print(f"    [{i:2d}] {name:<10}  n={n:>3}  best_known={bk}")

    print("\n  Selection options:")
    print("    • Press Enter            → all instances with n ≤ 20")
    print("    • n<=25  or  n<30        → size filter")
    print("    • all                    → all 18 instances")
    print("    • 1,3,7                  → comma-separated indices")
    sel_raw = input("\n  Your selection: ").strip() or "n<=20"

    if sel_raw.lower() == "all":
        selected = list(CURATED_INSTANCES)
    elif sel_raw.startswith("n<="):
        limit    = int(sel_raw[3:])
        selected = [n for n in CURATED_INSTANCES if INSTANCE_N.get(n,999) <= limit]
    elif sel_raw.startswith("n<"):
        limit    = int(sel_raw[2:])
        selected = [n for n in CURATED_INSTANCES if INSTANCE_N.get(n,999) < limit]
    else:
        idxs     = [int(s.strip())-1 for s in sel_raw.split(",") if s.strip().isdigit()]
        selected = [CURATED_INSTANCES[i] for i in idxs if 0 <= i < len(CURATED_INSTANCES)]
    print(f"  → Selected ({len(selected)}): {selected}\n")

    # Parameters
    n_trials = int(input("  GWMultiInit restarts [default=10]: ").strip() or "10")
    eps_raw  = input("  EGW epsilon values   [default=0.3,0.5,0.8]: ").strip() or "0.3,0.5,0.8"
    epsilons = tuple(float(e) for e in eps_raw.split(","))
    alp_raw  = input("  FGW alpha values     [default=0.3,0.5,0.7]: ").strip() or "0.3,0.5,0.7"
    alphas   = tuple(float(a) for a in alp_raw.split(","))

    capacity_seed = 42
    if mode == "varied":
        capacity_seed = int(input("  Capacity RNG seed    [default=42]: ").strip() or "42")

    print("\n  Exact solver: 2h per-instance limit.")
    print("  First instance that exceeds 2h → it and all larger get NA.\n")

    params = dict(n_gw_trials=n_trials, epsilons=epsilons, alphas=alphas,
                  exact_time_limit=7200, capacity_seed=capacity_seed)
    return mode, selected, params


