# 1. Automatic download
# ════════════════════════════════════════════════════════════════════════════

def _download_one(name, verbose=False):
    """
    Download <name>.dat from QAPLIB mirrors using stdlib urllib.
    Saves to QAPLIB_DATA_DIR/<name>.dat.  Returns True on success.
    """
    os.makedirs(QAPLIB_DATA_DIR, exist_ok=True)
    dest = os.path.join(QAPLIB_DATA_DIR, f"{name}.dat")
    if os.path.exists(dest):
        return True
    for url_tmpl in QAPLIB_URLS:
        url = url_tmpl.format(name=name)
        try:
            req = _urllib.Request(
                url, headers={"User-Agent": "Mozilla/5.0 (gw-cqap/1.0)"})
            with _urllib.urlopen(req, timeout=20) as resp:
                content = resp.read().decode("utf-8", errors="replace")
            int(content.strip().split()[0])   # sanity: must start with integer n
            with open(dest, "w") as fh:
                fh.write(content)
            if verbose:
                print(f"  ↓  {name}.dat")
            return True
        except Exception:
            continue
    return False


def download_instances(names):
    """
    Download all requested instances in one go.
    Prints a compact progress bar and returns the list of successfully
    downloaded names sorted by n.
    """
    print(f"\n  Downloading {len(names)} QAPLIB instances to "
          f"./{QAPLIB_DATA_DIR}/", end="", flush=True)
    ok, fail = [], []
    for name in names:
        success = _download_one(name)
        if success:
            ok.append(name)
            print(".", end="", flush=True)
        else:
            fail.append(name)
            print("✗", end="", flush=True)
    print()
    if fail:
        print(f"  Could not download: {fail}")
        print(f"  Manual download:  https://qaplib.mgi.polymtl.ca")
    ok_sorted = sorted(ok, key=lambda n: INSTANCE_N.get(n, 999))
    print(f"  {len(ok_sorted)} instances ready.")
    return ok_sorted


