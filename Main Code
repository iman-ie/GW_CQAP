# 6. Two-phase benchmark
# ════════════════════════════════════════════════════════════════════════════

def run_benchmark(names, mode, n_gw_trials=10,
                  epsilons=(0.3, 0.5, 0.8),
                  alphas=(0.3, 0.5, 0.7),
                  exact_time_limit=7200,
                  capacity_seed=42):
    """
    Two-phase benchmark on QAPLIB instances.

    Phase 1 – All approximate methods on every instance.
    Phase 2 – Exact (Gurobi), per-instance limit = exact_time_limit.
              Once one instance exceeds the limit all remaining → NA.

    mode = "simple"  : standard QAP (GW rounded to permutation)
    mode = "varied"  : CQAP (random capacities added to QAPLIB instance)
    """

    # ── build problem data ────────────────────────────────────────────────
    problems = []
    for name in names:
        try:
            n, F, D = load_qaplib_dat(name)
        except Exception as e:
            print(f"  [SKIP] {name}: {e}"); continue

        if mode == "simple":
            mu = np.ones(n); nu = np.ones(n)
            C1, C2, M = F, D, np.abs(F-D)/max(F.max(),D.max(),1e-12)
        else:
            mu, nu, C1, C2, M = add_random_capacities(n, F, D, seed=capacity_seed)

        total   = mu.sum()
        C2a, nua, Ma = augment_slack(C2, nu, mu, M)
        mu_n    = mu/total
        nu_n    = nua/total
        m_tasks = len(nu)   # original (non-augmented) task count
        problems.append(dict(name=name, n=n, F=F, D=D,
                             mu=mu, nu=nu, C1=C1, C2a=C2a, Ma=Ma,
                             mu_n=mu_n, nu_n=nu_n, m_tasks=m_tasks,
                             total=total))

    records = {p["name"]: {"id":p["name"],"n":p["n"]} for p in problems}

    def _obj(T, p):
        """Compute comparable objective: QAP obj (simple) or GW obj (varied)."""
        if mode == "simple":
            perm = round_to_perm(T)
            return compute_qap_obj(p["F"], p["D"], perm)
        else:
            m = p["m_tasks"]
            return compute_gw_obj(T[:,:m]*p["total"], p["C1"], p["C2a"][:m,:m])

    # ════════════════════════════════════
    # PHASE 1 — Approximate methods
    # ════════════════════════════════════
    print(f"\n{'='*62}")
    print(f"  PHASE 1 — Approximate Methods  [{mode.upper()} mode]")
    print(f"{'='*62}")

    for p in problems:
        name = p["name"]
        C1, C2a, Ma = p["C1"], p["C2a"], p["Ma"]
        mu_n, nu_n  = p["mu_n"], p["nu_n"]
        rec = records[name]
        print(f"\n  {name}  (n={p['n']})")

        # GW Default
        t0=time.time(); T=gw_default(C1,C2a,mu_n,nu_n); dt=time.time()-t0
        rec["GW_Default"]=_obj(T,p); rec["t_GW_Default"]=dt

        # GW MultiInit
        t0=time.time(); T=gw_multi_init(C1,C2a,mu_n,nu_n,n_trials=n_gw_trials)
        rec["GW_MultiInit"]=_obj(T,p); rec["t_GW_MultiInit"]=time.time()-t0

        # EGW — normalise cost matrices so epsilon is always in a meaningful range
        # Raw costs (e.g. tai instances) can be ~millions; eps=0.3 would give
        # exp(-1e6/0.3)=0 making Sinkhorn collapse. Normalising to [0,1] fixes this.
        _scale = max(float(C1.max()), float(C2a.max()), 1e-12)
        C1_n  = C1  / _scale
        C2a_n = C2a / _scale
        for eps in epsilons:
            t0=time.time()
            try:
                Te=ot.gromov.entropic_gromov_wasserstein(
                    C1_n, C2a_n, mu_n, nu_n, loss_fun="square_loss",
                    epsilon=eps, max_iter=2000, tol=1e-9)
                # Evaluate on ORIGINAL (un-normalised) costs for fair comparison
                obj=_obj(Te, p)
                if np.isnan(obj) or np.isinf(obj) or obj < 0:
                    obj = float("inf")
            except Exception:
                obj = float("inf")
            rec[f"EGW_{eps}"]=obj; rec[f"t_EGW_{eps}"]=time.time()-t0

        # FGW — also normalise costs for numerical stability
        _scale_fgw = max(float(C1.max()), float(C2a.max()), float(Ma.max()), 1e-12)
        C1_fn  = C1  / _scale_fgw
        C2a_fn = C2a / _scale_fgw
        Ma_fn  = Ma  / _scale_fgw
        for alpha in alphas:
            t0=time.time()
            try:
                Tf,_=ot.gromov.fused_gromov_wasserstein(
                    Ma_fn, C1_fn, C2a_fn, mu_n, nu_n,
                    loss_fun="square_loss", alpha=alpha, log=True)
                obj=_obj(Tf, p)
                if np.isnan(obj) or np.isinf(obj) or obj < 0:
                    obj = float("inf")
            except Exception:
                obj = float("inf")
            rec[f"FGW_{alpha}"]=obj; rec[f"t_FGW_{alpha}"]=time.time()-t0

        # GA
        t0=time.time()
        try:
            Tga=genetic_algorithm(C1,C2a,mu_n,nu_n,pop_size=80,generations=300)
            obj=_obj(Tga,p)
        except Exception: obj=float("inf")
        rec["GA"]=obj; rec["t_GA"]=time.time()-t0

        # Print row
        ref = KNOWN_BEST.get(name) if mode=="simple" else None
        for key in APPROX_METHODS:
            v=rec.get(key,float("inf")); t=rec.get(f"t_{key}",0)
            if v < float("inf"):
                gap = f"  gap={((v/ref)-1)*100:+.1f}%" if ref else ""
                print(f"    {key:<18}: {v:14.3f}  ({t:.2f}s){gap}")

    # ════════════════════════════════════
    # PHASE 2 — Exact solver
    # ════════════════════════════════════
    print(f"\n{'='*62}")
    print(f"  PHASE 2 — Exact Solver  "
          f"(limit = {exact_time_limit/3600:.1f}h per instance)")
    print(f"  Once one instance hits the limit, all remaining → NA")
    print(f"{'='*62}")

    exact_disabled = False

    for p in problems:
        name = p["name"]
        rec  = records[name]

        if exact_disabled:
            rec["Exact"]=None; rec["t_Exact"]=None; rec["exact_opt"]=None
            print(f"  {name} (n={p['n']}):  Exact = NA  (previous timeout)")
            continue

        print(f"\n  {name} (n={p['n']}):  running Exact … ", end="", flush=True)

        if mode == "simple":
            obj, elapsed, is_opt = solve_exact_qap(
                p["n"], p["F"], p["D"], time_limit=exact_time_limit)
        else:
            obj, elapsed, is_opt = solve_exact_cqap(
                p["mu"], p["nu"], p["C1"], p["C2a"][:p["m_tasks"],:p["m_tasks"]],
                time_limit=exact_time_limit)

        status = "[OPTIMAL]" if is_opt else "[TIME LIMIT]" if elapsed>=exact_time_limit*0.98 else "[FEASIBLE]"
        print(f"done  {elapsed:.1f}s  "
              + (f"obj={obj:.3f}  {status}" if obj is not None else f"obj=NA  {status}"))

        rec["Exact"]=obj; rec["t_Exact"]=elapsed; rec["exact_opt"]=is_opt

        if elapsed >= exact_time_limit * 0.98 or obj is None:
            exact_disabled = True
            print(f"  ⚠  Time limit reached — all larger instances will be NA.")

    return list(records.values())


