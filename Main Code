# 4. GW solvers
# ════════════════════════════════════════════════════════════════════════════

def gw_default(C1, C2, mu_n, nu_n):
    return ot.gromov.gromov_wasserstein(
        C1, C2, mu_n, nu_n, loss_fun="square_loss",
        max_iter=2000, tol=1e-10, verbose=False)


def gw_multi_init(C1, C2, mu_n, nu_n, n_trials=10):
    best_obj = float("inf"); best_T = None
    total = mu_n.sum()
    for seed in [None] + list(range(n_trials)):
        try:
            G0 = (None if seed is None else
                  _sinkhorn(np.random.rand(len(mu_n),len(nu_n))+1e-8, mu_n, nu_n))
            T  = ot.gromov.gromov_wasserstein(
                C1, C2, mu_n, nu_n, loss_fun="square_loss",
                max_iter=2000, tol=1e-10, G0=G0, verbose=False)
            obj = compute_gw_obj(T*total, C1, C2)
            if obj < best_obj:
                best_obj, best_T = obj, T
        except Exception:
            pass
    return best_T if best_T is not None else np.outer(mu_n, nu_n)


def genetic_algorithm(C1, C2, mu_n, nu_n, pop_size=80, generations=300):
    total = mu_n.sum()
    def fitness(P): return -compute_gw_obj(P*total, C1, C2)

    population = [np.outer(mu_n, nu_n)]
    try: population.append(gw_default(C1, C2, mu_n, nu_n))
    except Exception: pass
    while len(population) < pop_size:
        np.random.seed(len(population)*7)
        population.append(_sinkhorn(
            np.random.rand(len(mu_n),len(nu_n))+1e-8, mu_n, nu_n))

    best_hist = []; stagnation = 0
    for gen in range(generations):
        scores = [fitness(P) for P in population]
        best_hist.append(max(scores))
        if gen > 50:
            stagnation = stagnation+1 if best_hist[-1]-best_hist[-50]<1e-8 else 0
            if stagnation > 80: break
        def tour(k=3):
            idx = np.random.choice(len(population), k, replace=False)
            return population[max(idx, key=lambda ii: scores[ii])]
        elite_n = max(2, pop_size//10)
        new_pop = [population[i].copy() for i in np.argsort(scores)[-elite_n:]]
        while len(new_pop) < pop_size:
            p1, p2 = tour(), tour()
            a = np.random.uniform(0.3, 0.7)
            child = a*p1 + (1-a)*p2 if np.random.rand() < 0.8 else p1.copy()
            if np.random.rand() < 0.2:
                s = 0.1*np.exp(-gen/(generations*0.3))
                mask = np.random.rand(*child.shape) < 0.3
                child += mask*np.random.normal(0, s, child.shape)
            new_pop.append(_sinkhorn(child, mu_n, nu_n))
        population = new_pop
    scores = [fitness(P) for P in population]
    return population[np.argmax(scores)]


