# 3. Math utilities
# ════════════════════════════════════════════════════════════════════════════

def compute_gw_obj(T, C1, C2):
    mu = T.sum(1); nu = T.sum(0)
    return float(np.einsum("ij,i,j->", C1**2, mu, mu)
                 + np.einsum("kl,k,l->", C2**2, nu, nu)
                 - 2.*np.einsum("kl,kl->", C2, T.T @ C1 @ T))


def compute_qap_obj(F, D, perm):
    n = len(perm)
    return float(sum(F[i,j]*D[perm[i],perm[j]]
                     for i in range(n) for j in range(n)))


def round_to_perm(T):
    _, col = linear_sum_assignment(-T)
    return col


def _sinkhorn(P, mu, nu, n_iter=800, tol=1e-11):
    P = np.maximum(P, 1e-9)
    for it in range(n_iter):
        P *= mu[:,None] / P.sum(1, keepdims=True)
        P *= nu[None,:] / P.sum(0, keepdims=True)
        if it % 100 == 0:
            if (np.abs(P.sum(1)-mu).max() < tol and
                    np.abs(P.sum(0)-nu).max() < tol):
                break
    return P


def augment_slack(C2, nu, mu, M=None):
    slack = float(mu.sum() - nu.sum())
    if slack < 1e-10:
        return (C2, nu, M) if M is not None else (C2, nu)
    m    = len(nu)
    C2a  = np.zeros((m+1, m+1)); C2a[:m,:m] = C2
    nua  = np.append(nu, slack)
    if M is not None:
        Ma = np.zeros((len(mu), m+1)); Ma[:,:m] = M; Ma[:,m] = M.mean(1)
        return C2a, nua, Ma
    return C2a, nua


