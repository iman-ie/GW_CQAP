# 10. main
# ════════════════════════════════════════════════════════════════════════════

def main():
    OUT = "results"
    os.makedirs(OUT, exist_ok=True)

    # Interactive menu
    mode, selected_names, params = interactive_menu()

    # Auto-download all selected instances
    available = download_instances(selected_names)
    if not available:
        print("\n  No instances available. Check your internet connection.")
        print(f"  Or place .dat files manually in ./{QAPLIB_DATA_DIR}/")
        sys.exit(1)

    # Run two-phase benchmark
    records = run_benchmark(available, mode, **params)

    # Print results
    print_results_table(records, mode, params["epsilons"], params["alphas"])

    # Save CSV
    df       = records_to_df(records, mode, params["epsilons"], params["alphas"])
    csv_path = os.path.join(OUT, f"results_{mode}.csv")
    df.to_csv(csv_path, index=False)
    print(f"\n  Results CSV → {csv_path}")

    # Generate figures
    generate_figures(records, mode, params["epsilons"], params["alphas"], out_dir=OUT)
    print("\nDone.  All outputs in results/\n")


if __name__ == "__main__":
    main()
