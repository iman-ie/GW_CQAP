# 2. QAPLIB file parsing + capacity extension
# ════════════════════════════════════════════════════════════════════════════

def load_qaplib_dat(name):
    """
    Parse ./<QAPLIB_DATA_DIR>/<name>.dat  →  (n, F n×n, D n×n).
    F = flow matrix, D = distance matrix.
    """
    path = os.path.join(QAPLIB_DATA_DIR, f"{name}.dat")
    with open(path) as fh:
        tokens = fh.read().split()
    n    = int(tokens[0])
    vals = list(map(float, tokens[1:]))
    if len(vals) < 2*n*n:
        raise ValueError(f"{name}.dat: need {2*n*n} values, got {len(vals)}.")
    F = np.array(vals[:n*n]).reshape(n, n)
    D = np.array(vals[n*n:2*n*n]).reshape(n, n)
    return n, F, D


def add_random_capacities(n, F, D, seed=42):
    """
    Extend balanced QAP(F,D,n) to CQAP by assigning random integer
    capacities u_i to facilities and demands d_j to tasks.

        u_i ~ Uniform[2, 5]
        d_j ~ Uniform[1, 3],  then scaled so Σd = Σu  (balanced)

    Returns:  mu (capacities), nu (demands), C1=F, C2=D, M_feature
    """
    rng = np.random.default_rng(seed)
    u   = rng.integers(2, 6, size=n).astype(float)
    raw = rng.integers(1, 4, size=n).astype(float)
    d   = raw * (u.sum() / raw.sum())
    scale = max(F.max(), D.max(), 1e-12)
    M     = np.abs(F - D) / scale
    return u, d, F.copy(), D.copy(), M


